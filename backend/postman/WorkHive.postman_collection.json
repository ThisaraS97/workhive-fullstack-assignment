{
  "info": {
    "name": "WorkHive API",
    "description": "Postman collection for WorkHive job board API v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "applicationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Seeker",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Seeker\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"seeker\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken) {",
                  "  pm.collectionVariables.set('token', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker1@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs?location=Remote&category=Engineering&keyword=developer",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                { "key": "location", "value": "Remote" },
                { "key": "category", "value": "Engineering" },
                { "key": "keyword", "value": "developer" }
              ]
            }
          }
        },
        {
          "name": "Get Job By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Create Job (Employer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mid-Level React Developer\",\n  \"description\": \"Build modern web apps with React and TypeScript.\",\n  \"location\": \"Remote\",\n  \"category\": \"Engineering\",\n  \"salaryMin\": 90000,\n  \"salaryMax\": 120000\n}"
            },
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "My Posted Jobs (Employer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/mine"
          }
        },
        {
          "name": "Get Applicants (Employer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}/applicants"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Upload Resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "resume", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/resume/upload"
          }
        },
        {
          "name": "Apply to Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"coverLetter\": \"I am excited to apply for this role and believe my experience is a strong fit.\",\n  \"resumeUrl\": \"/uploads/resumes/sample.pdf\"\n}"
            },
            "url": "{{baseUrl}}/applications"
          }
        },
        {
          "name": "My Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/mine"
          }
        },
        {
          "name": "Update Applicant Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            },
            "url": "{{baseUrl}}/applications/{{applicationId}}/status"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List All Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/jobs"
          }
        },
        {
          "name": "Flag Job",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/jobs/{{jobId}}/flag"
          }
        },
        {
          "name": "Remove Job",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/jobs/{{jobId}}"
          }
        }
      ]
    }
  ]
}
