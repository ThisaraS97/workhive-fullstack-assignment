# Database
POSTGRES_USER=workhive
POSTGRES_PASSWORD=workhive_secret
POSTGRES_DB=workhive
DATABASE_URL=postgresql://workhive:workhive_secret@db:5432/workhive?schema=public

# Backend
PORT=5000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
UPLOAD_DIR=uploads

# Email (optional — uses Ethereal test account if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WorkHive <noreply@workhive.local>

# Frontend (local dev)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-secret-in-production
